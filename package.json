{
  "name": "jdm-experience",
  "private": true,
  "version": "0.0.0",
  "packageManager": "pnpm@10.4.1",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
