{
  "name": "@jdm/api",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch --env-file=.env src/server.ts",
    "build": "tsc -p tsconfig.build.json",
    "start": "node dist/server.js",
    "start:migrate": "pnpm --filter @jdm/db db:deploy && node dist/server.js",
    "pretest": "pnpm --filter @jdm/db db:generate",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src",
    "test": "vitest run"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1032.0",
    "@aws-sdk/s3-request-presigner": "^3.1032.0",
    "@fastify/cors": "^10.0.1",
    "@fastify/rate-limit": "^10.3.0",
    "@fastify/sensible": "^6.0.1",
    "@jdm/db": "workspace:*",
    "@jdm/shared": "workspace:*",
    "@paralleldrive/cuid2": "^3.3.0",
    "@prisma/client": "^6.1.0",
    "@sentry/node": "^8.42.0",
    "bcrypt": "^6.0.0",
    "expo-server-sdk": "^6.1.0",
    "fastify": "^5.1.0",
    "fastify-plugin": "^5.0.1",
    "jsonwebtoken": "^9.0.3",
    "node-cron": "^4.2.1",
    "pino": "^9.5.0",
    "resend": "^6.12.0",
    "stripe": "^22.1.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@jdm/tsconfig": "workspace:*",
    "@testcontainers/postgresql": "^10.13.0",
    "@types/bcrypt": "^6.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^22.19.17",
    "@types/node-cron": "^3.0.11",
    "pino-pretty": "^13.0.0",
    "testcontainers": "^10.13.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^3.0.0"
  }
}
