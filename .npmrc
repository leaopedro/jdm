# Expo/Metro requires physically hoisted node_modules at the root,
# so we opt out of pnpm's default isolated linker.
node-linker=hoisted

# Pin the pnpm store path so CI cache keys are stable across runs.
store-dir=~/.pnpm-store

# Strict peer deps off because Expo SDK + React Native peer graphs
# intentionally emit warnings on compatible versions.
strict-peer-dependencies=false
