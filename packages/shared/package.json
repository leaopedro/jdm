{
  "name": "@jdm/shared",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./dist/index.js"
    },
    "./admin": {
      "types": "./src/admin.ts",
      "default": "./dist/admin.js"
    },
    "./auth": {
      "types": "./src/auth.ts",
      "default": "./dist/auth.js"
    },
    "./cars": {
      "types": "./src/cars.ts",
      "default": "./dist/cars.js"
    },
    "./check-in": {
      "types": "./src/check-in.ts",
      "default": "./dist/check-in.js"
    },
    "./events": {
      "types": "./src/events.ts",
      "default": "./dist/events.js"
    },
    "./extras": {
      "types": "./src/extras.ts",
      "default": "./dist/extras.js"
    },
    "./health": {
      "types": "./src/health.ts",
      "default": "./dist/health.js"
    },
    "./ids": {
      "types": "./src/ids.ts",
      "default": "./dist/ids.js"
    },
    "./orders": {
      "types": "./src/orders.ts",
      "default": "./dist/orders.js"
    },
    "./cart": {
      "types": "./src/cart.ts",
      "default": "./dist/cart.js"
    },
    "./profile": {
      "types": "./src/profile.ts",
      "default": "./dist/profile.js"
    },
    "./push": {
      "types": "./src/push.ts",
      "default": "./dist/push.js"
    },
    "./notifications": {
      "types": "./src/notifications.ts",
      "default": "./dist/notifications.js"
    },
    "./store": {
      "types": "./src/store.ts",
      "default": "./dist/store.js"
    },
    "./support": {
      "types": "./src/support.ts",
      "default": "./dist/support.js"
    },
    "./tickets": {
      "types": "./src/tickets.ts",
      "default": "./dist/tickets.js"
    },
    "./uploads": {
      "types": "./src/uploads.ts",
      "default": "./dist/uploads.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "lint": "eslint src"
  },
  "dependencies": {
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@jdm/tsconfig": "workspace:*",
    "@types/node": "^22.0.0",
    "typescript": "^5.7.2",
    "vitest": "^3.0.0"
  }
}
